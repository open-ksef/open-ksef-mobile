<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit">

    <toolkit:IsNotNullConverter x:Key="IsNotNullConverter" />
    <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter" />

    <!-- ─── Page ─────────────────────────────────────────────── -->
    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="Padding" Value="0" />
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Light={StaticResource Background}, Dark={StaticResource Black}}" />
    </Style>

    <!-- ─── Shell ────────────────────────────────────────────── -->
    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor"
                Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource Gray950}}" />
        <Setter Property="Shell.ForegroundColor"
                Value="{StaticResource White}" />
        <Setter Property="Shell.TitleColor"
                Value="{StaticResource White}" />
        <Setter Property="Shell.TabBarBackgroundColor"
                Value="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource Gray950}}" />
        <Setter Property="Shell.TabBarForegroundColor"
                Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
        <Setter Property="Shell.TabBarUnselectedColor"
                Value="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}" />
        <Setter Property="Shell.TabBarTitleColor"
                Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
    </Style>

    <!-- ─── Label (implicit) ─────────────────────────────────── -->
    <Style TargetType="Label">
        <Setter Property="TextColor"
                Value="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextInverse}}" />
    </Style>

    <!-- ─── Label variants ───────────────────────────────────── -->
    <Style x:Key="LabelMuted" TargetType="Label">
        <Setter Property="TextColor"
                Value="{StaticResource TextMuted}" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style x:Key="LabelHeading" TargetType="Label">
        <Setter Property="TextColor"
                Value="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextInverse}}" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <Style x:Key="LabelCaption" TargetType="Label">
        <Setter Property="TextColor"
                Value="{StaticResource TextMuted}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="LabelFormLabel" TargetType="Label">
        <Setter Property="TextColor"
                Value="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <!-- ─── Entry (implicit) ─────────────────────────────────── -->
    <Style TargetType="Entry">
        <Setter Property="TextColor"
                Value="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextInverse}}" />
        <Setter Property="PlaceholderColor"
                Value="{StaticResource TextMuted}" />
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource Gray950}}" />
    </Style>

    <!-- ─── Editor (implicit) ────────────────────────────────── -->
    <Style TargetType="Editor">
        <Setter Property="TextColor"
                Value="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextInverse}}" />
        <Setter Property="PlaceholderColor"
                Value="{StaticResource TextMuted}" />
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource Gray950}}" />
    </Style>

    <!-- ─── Button (implicit: primary filled) ────────────────── -->
    <Style TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="TextColor" Value="{StaticResource White}" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="HeightRequest" Value="48" />
    </Style>

    <Style x:Key="ButtonSecondary" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="BorderColor" Value="{StaticResource Primary}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="HeightRequest" Value="48" />
    </Style>

    <Style x:Key="ButtonOutline" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="BorderColor" Value="{StaticResource Border}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="HeightRequest" Value="48" />
    </Style>

    <Style x:Key="ButtonDanger" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Error}" />
        <Setter Property="TextColor" Value="{StaticResource White}" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="HeightRequest" Value="48" />
    </Style>

    <Style x:Key="ButtonGhost" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource TextMuted}" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="HeightRequest" Value="48" />
    </Style>

    <Style x:Key="ButtonSmall" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="TextColor" Value="{StaticResource White}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="HeightRequest" Value="36" />
    </Style>

    <!-- ─── ActivityIndicator ────────────────────────────────── -->
    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{StaticResource Primary}" />
    </Style>

    <!-- ─── Border card style ────────────────────────────────── -->
    <Style x:Key="CardBorder" TargetType="Border">
        <Setter Property="Stroke" Value="{StaticResource Border}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 10,10,10,10" />
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource Gray950}}" />
        <Setter Property="Padding" Value="15" />
    </Style>

    <!-- ─── Frame card style ─────────────────────────────────── -->
    <Style x:Key="CardFrame" TargetType="Frame">
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource Gray950}}" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="HasShadow" Value="True" />
        <Setter Property="BorderColor" Value="Transparent" />
    </Style>

</ResourceDictionary>
